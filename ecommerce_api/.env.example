# .env.example — Copy this to .env and fill in your values
# NEVER commit .env to git (it's in .gitignore)

# Django
SECRET_KEY=your-very-long-random-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (for local development with SQLite, leave DATABASE_URL blank)
# For MySQL: mysql://user:password@localhost:3306/dbname
# For PostgreSQL: postgresql://user:password@localhost:5432/dbname
DATABASE_URL=

# Redis (for Celery)
REDIS_URL=redis://localhost:6379/0

# Email (use console backend for development — prints to terminal)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=noreply@yourstore.com

# Frontend URL (for CORS)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Inventory threshold — alert when stock falls below this
LOW_STOCK_THRESHOLD=10
